[
  {
    "kernelSource": {
      "name": "alioth_art",
      "repo": "https://github.com/Death8023/InfiniR_kernel_alioth.git",
      "branch": "14.0-alioth",
      "device": "alioth",
      "defconfig": "alioth_defconfig"
    },
    "toolchains": [
      {
        "repo": "https://github.com/ZyCromerZ/Clang.git",
        "branch": "main",
        "name": "clang",
        "binaryEnv": [
          "bin"
        ]
      },
    ],
    "enableCcache": true,
    "params": {
      "ARCH": "arm64",
      "CC": "clang",
      "externalCommands": {
        "CLANG_TRIPLE": "aarch64-linux-gnu-",
        "CROSS_COMPILE": "aarch64-linux-android-",
        "CROSS_COMPILE_ARM32": "arm-linux-androideabi-",
        "LD": "ld.lld",
        "AR": "llvm-ar",
        "NM": "llvm-nm",
        "OBJCOPY": "llvm-objcopy",
        "OBJDUMP": "llvm-objdump",
        "READELF": "llvm-readelf",
        "OBJSIZE": "llvm-size",
        "STRIP": "llvm-strip",
        "LDGOLD": "aarch64-linux-gnu-ld.gold",
        "LLVM_AR": "llvm-ar",
        "LLVM_DIS": "llvm-dis",
        "CONFIG_THINLTO": ""
      }
    },
    "AnyKernel3": {
      "use": true,
      "release": true
    },
    "enableKernelSU": true,
    "enableLXC": false
  }
]
