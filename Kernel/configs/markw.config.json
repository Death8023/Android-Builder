[
  {
    "kernelSource": {
      "name": "alioth",
      "repo": "https://github.com/Death8023/InfiniR_kernel_alioth.git",
      "branch": "14.0-alioth",
      "device": "alioth",
      "defconfig": "alioth_defconfig"
    },
    "enableCcache": true,
    "toolchains": [
  {
    "name": "clang",
    "url": "https://github.com/ZyCromerZ/Clang/releases/download/19.0.0git-20240315-release/Clang-19.0.0git-20240315.tar.gz",
    "binaryEnv": ["./bin"]
  },
  {
    "name": "gcc",
    "url": "https://android.googlesource.com/platform/prebuilts/gcc/linux-x86/aarch64/aarch64-linux-android-4.9/+archive/refs/tags/android-12.1.0_r27.tar.gz",
    "binaryEnv": ["bin"]
  }
],
    "params": {
  "ARCH": "arm64",
  "CC": "clang",
  "externalCommands": {
    "CLANG_TRIPLE": "aarch64-linux-gnu-",
    "CROSS_COMPILE": "proton-clang/bin/aarch64-linux-gnu-",
    "CROSS_COMPILE_ARM32": "proton-clang/bin/arm-linux-gnueabi-"
  }
},
    "AnyKernel3": {
      "use": true,
      "release": true
    },
    "enableKernelSU": true,
    "enableLXC": false
  }
]
